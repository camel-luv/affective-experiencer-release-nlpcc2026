{"item_id": "ZH_fear_001_SE", "language": "ZH", "context": "深夜在野外露营，何芸独自外出查看营地动静，几个小时都没有回来。吴盛害怕何芸在外面出了意外。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "stimulus"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "experiencer"}], "affective_event": {"lexical_item": "害怕", "sememe_node_id": "fear|害怕", "polarity": "neg"}, "task_format_qa": {"question": "谁感到害怕？", "options": ["何芸", "吴盛"], "gold_index": 1}, "task_format_paraphrase": {"options": ["何芸感到害怕。", "吴盛感到害怕。"], "gold_index": 1}, "experiencer_role_position": "subject", "belletti_rizzi_class": "I", "donor_pair_pointer": {"same_affect": "ZH_hate_001_SE", "affect_flipped": "ZH_love_001_SE"}, "naturalness_score": null}
{"item_id": "ZH_love_001_SE", "language": "ZH", "context": "何芸搬到吴盛隔壁公寓。吴盛从相识的第一天就爱上了何芸。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "stimulus"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "experiencer"}], "affective_event": {"lexical_item": "爱", "sememe_node_id": "love|爱", "polarity": "pos"}, "task_format_qa": {"question": "谁感到爱意？", "options": ["何芸", "吴盛"], "gold_index": 1}, "task_format_paraphrase": {"options": ["何芸心生爱意。", "吴盛心生爱意。"], "gold_index": 1}, "experiencer_role_position": "subject", "belletti_rizzi_class": "I", "donor_pair_pointer": {"same_affect": "ZH_FondOf_001_SE", "affect_flipped": "ZH_fear_001_SE"}, "naturalness_score": null}
{"item_id": "ZH_hate_001_SE", "language": "ZH", "context": "在同事面前，吴盛在会议上对何芸撒了谎。何芸为此恨吴盛。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "experiencer"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "stimulus"}], "affective_event": {"lexical_item": "恨", "sememe_node_id": "hate|仇恨", "polarity": "neg"}, "task_format_qa": {"question": "谁感到仇恨？", "options": ["何芸", "吴盛"], "gold_index": 0}, "task_format_paraphrase": {"options": ["何芸感到仇恨。", "吴盛感到仇恨。"], "gold_index": 0}, "experiencer_role_position": "subject", "belletti_rizzi_class": "I", "donor_pair_pointer": {"same_affect": "ZH_sorrowful_001_SE", "affect_flipped": "ZH_FondOf_001_SE"}, "naturalness_score": null}
{"item_id": "ZH_FondOf_001_SE", "language": "ZH", "context": "何芸在养犬基地训练狗，吴盛在那里做周末志愿者。吴盛喜欢何芸冷静的态度。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "stimulus"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "experiencer"}], "affective_event": {"lexical_item": "喜欢", "sememe_node_id": "FondOf|喜欢", "polarity": "pos"}, "task_format_qa": {"question": "谁感到喜爱？", "options": ["何芸", "吴盛"], "gold_index": 1}, "task_format_paraphrase": {"options": ["何芸感到喜爱。", "吴盛感到喜爱。"], "gold_index": 1}, "experiencer_role_position": "subject", "belletti_rizzi_class": "I", "donor_pair_pointer": {"same_affect": "ZH_enjoy_001_SE", "affect_flipped": "ZH_hate_001_SE"}, "naturalness_score": null}
{"item_id": "ZH_enjoy_001_SE", "language": "ZH", "context": "在家庭聚餐时，吴盛整个晚上都在讲故事。何芸享受吴盛的陪伴胜过享受食物。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "experiencer"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "stimulus"}], "affective_event": {"lexical_item": "享受", "sememe_node_id": "enjoy|享受", "polarity": "pos"}, "task_format_qa": {"question": "谁感到享受？", "options": ["何芸", "吴盛"], "gold_index": 0}, "task_format_paraphrase": {"options": ["何芸感到享受。", "吴盛感到享受。"], "gold_index": 0}, "experiencer_role_position": "subject", "belletti_rizzi_class": "I", "donor_pair_pointer": {"same_affect": "ZH_love_001_SE", "affect_flipped": "ZH_sorrowful_001_SE"}, "naturalness_score": null}
{"item_id": "ZH_sorrowful_001_SE", "language": "ZH", "context": "何芸已经在医院重病数周，吴盛为何芸日益恶化的病情感到悲哀。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "stimulus"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "experiencer"}], "affective_event": {"lexical_item": "悲哀", "sememe_node_id": "sorrowful|悲哀", "polarity": "neg"}, "task_format_qa": {"question": "谁感到悲哀？", "options": ["何芸", "吴盛"], "gold_index": 1}, "task_format_paraphrase": {"options": ["何芸感到悲哀。", "吴盛感到悲哀。"], "gold_index": 1}, "experiencer_role_position": "subject", "belletti_rizzi_class": "I", "donor_pair_pointer": {"same_affect": "ZH_fear_001_SE", "affect_flipped": "ZH_enjoy_001_SE"}, "naturalness_score": null}
{"item_id": "ZH_fear_001_OE", "language": "ZH", "context": "吴盛在黑暗的房间里突然大喊一声冲了进来。吴盛吓住了何芸。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "experiencer"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "stimulus"}], "affective_event": {"lexical_item": "吓住", "sememe_node_id": "fear|害怕", "polarity": "neg"}, "task_format_qa": {"question": "谁感到害怕？", "options": ["何芸", "吴盛"], "gold_index": 0}, "task_format_paraphrase": {"options": ["何芸感到害怕。", "吴盛感到害怕。"], "gold_index": 0}, "experiencer_role_position": "object", "belletti_rizzi_class": "II", "donor_pair_pointer": {"same_affect": "ZH_irritate_001_OE", "affect_flipped": "ZH_joyful_001_OE"}, "naturalness_score": null}
{"item_id": "ZH_irritate_001_OE", "language": "ZH", "context": "在长时间的技术会议上，何芸一直打断吴盛的发言。何芸激怒了吴盛。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "stimulus"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "experiencer"}], "affective_event": {"lexical_item": "激怒", "sememe_node_id": "irritate|激怒", "polarity": "neg"}, "task_format_qa": {"question": "谁感到生气？", "options": ["何芸", "吴盛"], "gold_index": 1}, "task_format_paraphrase": {"options": ["何芸感到生气。", "吴盛感到生气。"], "gold_index": 1}, "experiencer_role_position": "object", "belletti_rizzi_class": "II", "donor_pair_pointer": {"same_affect": "ZH_shy_001_OE", "affect_flipped": "ZH_calm_001_OE"}, "naturalness_score": null}
{"item_id": "ZH_shy_001_OE", "language": "ZH", "context": "在正式的晚宴上，吴盛把红酒洒到了何芸的衣服上。吴盛当众使何芸难堪。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "experiencer"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "stimulus"}], "affective_event": {"lexical_item": "使...难堪", "sememe_node_id": "shy|羞愧", "polarity": "neg"}, "task_format_qa": {"question": "谁感到难堪？", "options": ["何芸", "吴盛"], "gold_index": 0}, "task_format_paraphrase": {"options": ["何芸感到难堪。", "吴盛感到难堪。"], "gold_index": 0}, "experiencer_role_position": "object", "belletti_rizzi_class": "II", "donor_pair_pointer": {"same_affect": "ZH_fear_001_OE", "affect_flipped": "ZH_excite_001_OE"}, "naturalness_score": null}
{"item_id": "ZH_joyful_001_OE", "language": "ZH", "context": "为庆祝吴盛的生日，何芸在俱乐部里精心组织了一场惊喜派对。何芸的心意让吴盛十分高兴。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "stimulus"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "experiencer"}], "affective_event": {"lexical_item": "让...高兴", "sememe_node_id": "joyful|喜悦", "polarity": "pos"}, "task_format_qa": {"question": "谁感到高兴？", "options": ["何芸", "吴盛"], "gold_index": 1}, "task_format_paraphrase": {"options": ["何芸感到高兴。", "吴盛感到高兴。"], "gold_index": 1}, "experiencer_role_position": "object", "belletti_rizzi_class": "II", "donor_pair_pointer": {"same_affect": "ZH_calm_001_OE", "affect_flipped": "ZH_fear_001_OE"}, "naturalness_score": null}
{"item_id": "ZH_calm_001_OE", "language": "ZH", "context": "在演讲前，何芸十分紧张。吴盛在后台用一句温柔的话安慰了何芸。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "experiencer"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "stimulus"}], "affective_event": {"lexical_item": "安慰", "sememe_node_id": "calm|镇静", "polarity": "pos"}, "task_format_qa": {"question": "谁感到被安慰？", "options": ["何芸", "吴盛"], "gold_index": 0}, "task_format_paraphrase": {"options": ["何芸感到被安慰。", "吴盛感到被安慰。"], "gold_index": 0}, "experiencer_role_position": "object", "belletti_rizzi_class": "II", "donor_pair_pointer": {"same_affect": "ZH_excite_001_OE", "affect_flipped": "ZH_irritate_001_OE"}, "naturalness_score": null}
{"item_id": "ZH_excite_001_OE", "language": "ZH", "context": "何芸买了总决赛的门票，把票拿给吴盛看。何芸让吴盛对这次观看比赛感到激动。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "stimulus"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "experiencer"}], "affective_event": {"lexical_item": "让...激动", "sememe_node_id": "excite|感动", "polarity": "pos"}, "task_format_qa": {"question": "谁感到激动？", "options": ["何芸", "吴盛"], "gold_index": 1}, "task_format_paraphrase": {"options": ["何芸感到激动。", "吴盛感到激动。"], "gold_index": 1}, "experiencer_role_position": "object", "belletti_rizzi_class": "II", "donor_pair_pointer": {"same_affect": "ZH_joyful_001_OE", "affect_flipped": "ZH_shy_001_OE"}, "naturalness_score": null}
{"item_id": "ZH_like_001_SE", "language": "ZH", "context": "何芸在音乐学院礼堂连续听了吴盛两小时的小提琴演奏。何芸欣赏吴盛对艺术的执着。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "experiencer"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "stimulus"}], "affective_event": {"lexical_item": "欣赏", "sememe_node_id": "like|爱惜", "polarity": "pos"}, "task_format_qa": {"question": "谁感到欣赏？", "options": ["何芸", "吴盛"], "gold_index": 0}, "task_format_paraphrase": {"options": ["何芸感到欣赏。", "吴盛感到欣赏。"], "gold_index": 0}, "experiencer_role_position": "subject", "belletti_rizzi_class": "I", "donor_pair_pointer": {"same_affect": "ZH_BeInLove_001_SE", "affect_flipped": "ZH_worried_001_SE"}, "naturalness_score": null}
{"item_id": "ZH_BeInLove_001_SE", "language": "ZH", "context": "何芸和吴盛在同一家书店共事两年。两年下来，吴盛深深倾心于何芸。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "stimulus"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "experiencer"}], "affective_event": {"lexical_item": "倾心于", "sememe_node_id": "BeInLove|恋爱", "polarity": "pos"}, "task_format_qa": {"question": "谁陷入爱恋？", "options": ["何芸", "吴盛"], "gold_index": 1}, "task_format_paraphrase": {"options": ["何芸陷入爱恋。", "吴盛陷入爱恋。"], "gold_index": 1}, "experiencer_role_position": "subject", "belletti_rizzi_class": "I", "donor_pair_pointer": {"same_affect": "ZH_grateful_001_SE", "affect_flipped": "ZH_jealous_001_SE"}, "naturalness_score": null}
{"item_id": "ZH_grateful_001_SE", "language": "ZH", "context": "去年春天暴雨淹了何芸的地下室，吴盛开车赶来帮忙整整一天。何芸感激吴盛的及时救援。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "experiencer"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "stimulus"}], "affective_event": {"lexical_item": "感激", "sememe_node_id": "grateful|感激", "polarity": "pos"}, "task_format_qa": {"question": "谁心怀感激？", "options": ["何芸", "吴盛"], "gold_index": 0}, "task_format_paraphrase": {"options": ["何芸心怀感激。", "吴盛心怀感激。"], "gold_index": 0}, "experiencer_role_position": "subject", "belletti_rizzi_class": "I", "donor_pair_pointer": {"same_affect": "ZH_like_001_SE", "affect_flipped": "ZH_lonely_001_SE"}, "naturalness_score": null}
{"item_id": "ZH_worried_001_SE", "language": "ZH", "context": "何芸在山里徒步至日落仍未返回。吴盛整晚都在担心何芸的安危。", "characters": [{"position": 0, "name": "何芸", "gender": "f", "animacy": "human", "role": "stimulus"}, {"position": 1, "name": "吴盛", "gender": "m", "animacy": "human", "role": "experiencer"}], "affective_event": {"lexical_item": "担心", "sememe_node_id": "worried|着急", "polarity": "neg"}, "task_format_qa": {"question": "谁感到担心？", "options": ["何芸", "吴盛"], "gold_index": 1}, "task_format_paraphrase": {"options": ["何芸感到担心。", "吴盛感到担心。"], "gold_index": 1}, "experiencer_role_position": "subject", "belletti_rizzi_class": "I", "donor_pair_pointer": {"same_affect": "ZH_jealous_001_SE", "affect_flipped": "ZH_like_001_SE"}, "naturalness_score": null}
